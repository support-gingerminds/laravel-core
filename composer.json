{
    "name": "gingerminds/laravel-core",
    "description": "Core CRUD and API functionalities for Laravel projects",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Gingerminds\\LaravelCore\\": "src/",
            "Gingerminds\\LaravelCore\\Database\\Factories\\": "src/Database/Factories/",
            "Gingerminds\\LaravelCore\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "Gingerminds"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "api-platform/laravel": "^4.3",
        "laravel/sanctum": "^4.2",
        "laravel/tinker": "^2.9",
        "livewire/livewire": "^3.5",
        "spatie/laravel-permission": "^6.23"
    },
    "require-dev": {
        "larastan/larastan": "^3.8",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^2.0",
        "phpdocumentor/type-resolver": "^1.8"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gingerminds\\LaravelCore\\Providers\\LaravelCoreServiceProvider",
                "Gingerminds\\LaravelCore\\Providers\\LaravelCoreAuthServiceProvider"
            ]
        }
    }
}
